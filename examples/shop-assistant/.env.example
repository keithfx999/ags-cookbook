# Copy this file to .env and fill in real values
# E2B_API_KEY is provided by Tencent Cloud Agent Sandbox product
E2B_API_KEY=your_ags_api_key
E2B_DOMAIN=ap-guangzhou.tencentags.com

# Required run-time asset:
# - cookie.json (export your logged-in Amazon cookies)
# You can copy and edit the provided template:
# cp cookie.json.example cookie.json
